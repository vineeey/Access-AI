<?xml version="1.0" encoding="utf-8"?>
<!--
  AccessAI talks to a FastAPI backend running on the user's own laptop over the
  LAN via PLAIN http:// (e.g. http://192.168.1.78:8000). Android 9+ blocks
  cleartext HTTP by default, which would make the app silently unable to reach
  the server. The server address is user-configurable to an arbitrary private
  LAN IP, so we can't whitelist a fixed <domain>; instead we permit cleartext
  globally. This is acceptable for a LAN appliance / dev build. System trust
  anchors are kept so any future https:// endpoint still validates normally.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
